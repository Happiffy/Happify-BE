{
  "name": "be-happify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "test": "tsx --test src/utils/request.util.test.ts src/modules/voice/voice.validation.test.ts src/modules/analytics/analytics.service.test.ts src/modules/device/firmware-compatibility.test.ts src/modules/device/firmware-discovery-contract.test.ts",
    "start": "tsx src/server.ts",
    "seed": "prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "simulator:register": "tsx scripts/register-device-simulator.ts",
    "simulator:telemetry": "tsx scripts/send-device-telemetry.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "sanitize-html": "^2.17.5",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.0",
    "@types/sanitize-html": "^2.16.1",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
