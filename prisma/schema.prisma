generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MoodState {
  HAPPY
  CALM
  NEUTRAL
  ANXIOUS
  SAD
  DISTRESSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRISIS
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ChatSessionStatus {
  OPEN
  CLOSED
}

enum ConsentScope {
  AI_PROCESSING
  VOICE_PROCESSING
  DEVICE_EMOTION_OBSERVATION
  HEATMAP_CONTRIBUTION
}

enum ConsentStatus {
  ACCEPTED
  REVOKED
}

enum AccessibilityTextScale {
  SMALL
  STANDARD
  LARGE
  EXTRA_LARGE
}

enum CommunityTargetType {
  POST
  COMMENT
}

enum CommunityReportReason {
  HARASSMENT
  SELF_HARM
  SPAM
  MISINFORMATION
  PRIVACY
  OTHER
}

enum CommunityReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ModerationAction {
  HIDE
  RESTORE
  RESOLVE_REPORT
  DISMISS_REPORT
}

enum MindfulnessType {
  BREATHING
  MEDITATION
  GROUNDING
}

enum MindfulnessProgressStatus {
  STARTED
  COMPLETED
}

enum ProviderType {
  PSYCHOLOGIST
  COUNSELOR
  CRISIS_LINE
  CLINIC
}

enum DeviceStatus {
  UNPAIRED
  PAIRED
  REVOKED
}

enum DevicePairingStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum DeviceCommandType {
  HAPTIC_THERAPY
  DISPLAY_MESSAGE
  SET_CONFIGURATION
  RESTART
}

enum DeviceCommandStatus {
  PENDING
  ACKNOWLEDGED
  COMPLETED
  FAILED
  CANCELLED
}

enum EmotionObservationSource {
  VOICE
  CAMERA
  FUSED
}

enum DeviceCheckInKind {
  MOOD
  CHECK_IN
}

enum FirmwareStatus {
  ACTIVE
  DEPRECATED
}

enum OtaStatus {
  PENDING
  DOWNLOADING
  INSTALLING
  SUCCEEDED
  FAILED
  CANCELLED
}

model MsRole {
  code  String   @id
  users MsUser[]
}

model MsUser {
  id                       String                       @id @default(cuid())
  firebaseUid              String                       @unique
  email                    String?                      @unique
  displayName              String?
  role                     String                       @default("USER")
  roleRecord               MsRole                       @relation(fields: [role], references: [code], onDelete: Restrict)
  avatarUrl                String?
  bio                      String?
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  moods                    TrMoodEntry[]
  journals                 TrJournalEntry[]
  posts                    TrCommunityPost[]
  comments                 TrCommunityComment[]
  communitySupports        TrCommunitySupport[]
  communityReports         TrCommunityReport[]          @relation("CommunityReporter")
  moderationAudits         TrCommunityModerationAudit[]
  moodGeoPoints            TrMoodGeoPoint[]
  heatmapContributions     TrHeatmapContribution[]
  referrals                TrReferral[]                 @relation("ReferralUser")
  reviewedReferrals        TrReferral[]                 @relation("ReferralPsychologist")
  careChatSessions         TrCareChatSession[]          @relation("CareChatUser")
  psychologistChatSessions TrCareChatSession[]          @relation("CareChatPsychologist")
  careChatMessages         TrCareChatMessage[]
  preference               MsUserPreference?
  psychologistApplication  TrPsychologistApplication?   @relation("PsychologistApplicationUser")
  fcmTokens                TrFcmToken[]
  devices                  MsDevice[]
  devicePairingSessions    TrDevicePairingSession[]
  voiceTurns               TrVoiceTurn[]
  consents                 TrUserConsent[]
  mindfulnessProgress      TrMindfulnessProgress[]
  emergencyContacts        MsEmergencyContact[]
  emotionObservations      TrDeviceEmotionObservation[]
  deviceCheckIns           TrDeviceCheckIn[]            @relation("DeviceCheckInUser")
  reviewedApplications     TrPsychologistApplication[]  @relation("PsychologistApplicationReviewer")

  @@index([role])
  @@index([createdAt])
}

model MsConsentDocument {
  id          String          @id @default(cuid())
  scope       ConsentScope
  version     Int
  title       String
  content     String
  isActive    Boolean         @default(true)
  effectiveAt DateTime
  createdAt   DateTime        @default(now())
  consents    TrUserConsent[]

  @@unique([scope, version])
  @@index([scope, isActive, effectiveAt])
}

model TrUserConsent {
  id           String                       @id @default(cuid())
  userId       String
  documentId   String
  scope        ConsentScope
  version      Int
  status       ConsentStatus
  acceptedAt   DateTime?
  revokedAt    DateTime?
  source       String
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  user         MsUser                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  document     MsConsentDocument            @relation(fields: [documentId], references: [id], onDelete: Restrict)
  observations TrDeviceEmotionObservation[]

  @@unique([userId, documentId])
  @@index([userId, scope, status, updatedAt])
  @@index([documentId])
}

model TrFcmToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  platform   String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       MsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MsDevice {
  id                    String                       @id @default(cuid())
  serialNumber          String                       @unique
  model                 String
  displayName           String?
  claimSecretDigest     String
  ownerId               String?
  status                DeviceStatus                 @default(UNPAIRED)
  pairedAt              DateTime?
  unpairedAt            DateTime?
  revokedAt             DateTime?
  lastSeenAt            DateTime?
  firmwareVersion       String?
  hardwareRevision      String?
  bootloaderVersion     String?
  protocolVersion       String?
  supportedCommandTypes DeviceCommandType[]          @default([])
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  owner                 MsUser?                      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  pairingSessions       TrDevicePairingSession[]
  credentials           TrDeviceCredential[]
  telemetry             TrDeviceTelemetry[]
  commands              TrDeviceCommand[]
  otaDeployments        TrDeviceOtaDeployment[]
  emotionObservations   TrDeviceEmotionObservation[]
  checkIns              TrDeviceCheckIn[]

  @@index([ownerId, updatedAt])
  @@index([status])
}

model TrDevicePairingSession {
  id          String              @id @default(cuid())
  deviceId    String
  userId      String
  status      DevicePairingStatus @default(PENDING)
  expiresAt   DateTime
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  device      MsDevice            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user        MsUser              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([deviceId, status])
  @@index([status, expiresAt])
}

model TrDeviceCredential {
  id          String    @id @default(cuid())
  deviceId    String
  tokenDigest String    @unique
  expiresAt   DateTime
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  device      MsDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, revokedAt, expiresAt])
}

model TrDeviceTelemetry {
  id         String   @id @default(cuid())
  deviceId   String
  metric     String
  value      Float
  unit       String?
  recordedAt DateTime
  receivedAt DateTime @default(now())
  metadata   Json?
  device     MsDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, recordedAt])
  @@index([metric, recordedAt])
}

model TrDeviceEmotionObservation {
  id                      String                     @id @default(cuid())
  deviceId                String
  userId                  String
  source                  EmotionObservationSource
  inputSources            EmotionObservationSource[] @default([])
  state                   MoodState
  confidence              Float
  riskLevel               RiskLevel
  facePresent             Boolean?
  eyeContact              Boolean?
  expressionProbabilities Json?
  observationProvider     String
  modelName               String
  modelVersion            String
  consentId               String
  consentVersion          Int
  retentionPolicy         String
  retainUntil             DateTime
  idempotencyKey          String
  observedAt              DateTime
  receivedAt              DateTime                   @default(now())
  device                  MsDevice                   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user                    MsUser                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consent                 TrUserConsent              @relation(fields: [consentId], references: [id], onDelete: Restrict)

  @@unique([deviceId, idempotencyKey])
  @@index([deviceId, observedAt])
  @@index([userId, observedAt])
  @@index([retainUntil])
}

model TrDeviceCheckIn {
  id             String            @id @default(cuid())
  deviceId       String
  userId         String
  moodId         String            @unique
  kind           DeviceCheckInKind
  idempotencyKey String
  observedAt     DateTime
  receivedAt     DateTime          @default(now())
  device         MsDevice          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user           MsUser            @relation("DeviceCheckInUser", fields: [userId], references: [id], onDelete: Cascade)
  mood           TrMoodEntry       @relation(fields: [moodId], references: [id], onDelete: Cascade)

  @@unique([deviceId, idempotencyKey])
  @@index([userId, observedAt])
}

model TrDeviceCommand {
  id             String              @id @default(cuid())
  deviceId       String
  type           DeviceCommandType
  payload        Json
  status         DeviceCommandStatus @default(PENDING)
  idempotencyKey String?
  acknowledgedAt DateTime?
  completedAt    DateTime?
  errorCode      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  device         MsDevice            @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, idempotencyKey])
  @@index([deviceId, status, createdAt])
}

model MsFirmwareRelease {
  id                       String                  @id @default(cuid())
  model                    String
  version                  String
  hardwareRevision         String?
  minimumBootloaderVersion String?
  protocolVersion          String
  downloadUrl              String
  checksumSha256           String
  releaseNotes             String?
  status                   FirmwareStatus          @default(ACTIVE)
  createdAt                DateTime                @default(now())
  otaDeployments           TrDeviceOtaDeployment[]

  @@unique([model, version])
  @@index([model, status, createdAt])
}

model TrDeviceOtaDeployment {
  id          String            @id @default(cuid())
  deviceId    String
  firmwareId  String
  status      OtaStatus         @default(PENDING)
  progress    Int               @default(0)
  errorCode   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  device      MsDevice          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  firmware    MsFirmwareRelease @relation(fields: [firmwareId], references: [id], onDelete: Restrict)

  @@index([deviceId, status, createdAt])
  @@index([firmwareId])
}

model TrVoiceTurn {
  id                String      @id @default(cuid())
  userId            String
  sessionId         String?
  idempotencyKey    String?
  language          String
  transcript        String?
  responseText      String?
  detectedMood      MoodState?
  emotionConfidence Float?
  riskLevel         RiskLevel?
  upstreamRequestId String?
  upstreamAudioPath String?
  audioExpiresAt    DateTime?
  referralId        String?     @unique
  createdAt         DateTime    @default(now())
  user              MsUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  referral          TrReferral? @relation(fields: [referralId], references: [id], onDelete: SetNull)

  @@unique([userId, idempotencyKey])
  @@index([userId, sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([detectedMood, createdAt])
  @@index([riskLevel, createdAt])
  @@index([audioExpiresAt])
}

model TrMoodEntry {
  id            String           @id @default(cuid())
  userId        String
  state         MoodState
  intensity     Int              @default(3)
  triggers      String[]         @default([])
  note          String?
  createdAt     DateTime         @default(now())
  user          MsUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceCheckIn TrDeviceCheckIn?

  @@index([userId, createdAt])
  @@index([state, createdAt])
}

model TrJournalEntry {
  id           String     @id @default(cuid())
  userId       String
  title        String
  content      String
  imageUrl     String?
  detectedMood MoodState?
  riskLevel    RiskLevel  @default(LOW)
  aiReflection String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         MsUser     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([riskLevel, createdAt])
}

model TrCommunityPost {
  id           String               @id @default(cuid())
  userId       String?
  alias        String               @default("Anonymous")
  content      String
  imageUrl     String?
  mood         MoodState?
  supportCount Int                  @default(0)
  isHidden     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  user         MsUser?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  supports     TrCommunitySupport[]
  comments     TrCommunityComment[]
  reports      TrCommunityReport[]

  @@index([createdAt])
  @@index([isHidden, createdAt])
}

model TrCommunitySupport {
  id        String          @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime        @default(now())
  user      MsUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      TrCommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model TrCommunityComment {
  id        String              @id @default(cuid())
  postId    String
  userId    String?
  alias     String              @default("Anonymous")
  content   String
  imageUrl  String?
  isHidden  Boolean             @default(false)
  createdAt DateTime            @default(now())
  post      TrCommunityPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      MsUser?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  reports   TrCommunityReport[]

  @@index([postId, createdAt])
  @@index([isHidden, createdAt])
}

model TrCommunityReport {
  id         String                @id @default(cuid())
  reporterId String
  targetType CommunityTargetType
  targetId   String
  postId     String?
  commentId  String?
  reason     CommunityReportReason
  details    String?
  status     CommunityReportStatus @default(OPEN)
  resolvedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  reporter   MsUser                @relation("CommunityReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post       TrCommunityPost?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    TrCommunityComment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetType, targetId])
  @@index([status, createdAt])
  @@index([postId])
  @@index([commentId])
}

model TrCommunityModerationAudit {
  id          String              @id @default(cuid())
  moderatorId String
  action      ModerationAction
  targetType  CommunityTargetType
  targetId    String
  reportId    String?
  reason      String
  metadata    Json?
  createdAt   DateTime            @default(now())
  moderator   MsUser              @relation(fields: [moderatorId], references: [id], onDelete: Restrict)

  @@index([moderatorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([reportId])
}

model TrMoodGeoPoint {
  id          String    @id @default(cuid())
  userId      String?
  regionLabel String
  latitude    Float
  longitude   Float
  mood        MoodState
  createdAt   DateTime  @default(now())
  user        MsUser?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([regionLabel, createdAt])
  @@index([mood, createdAt])
}

model TrHeatmapContribution {
  id         String    @id @default(cuid())
  userId     String
  regionKey  String
  mood       MoodState
  bucketDate DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       MsUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bucketDate])
  @@index([regionKey, bucketDate, mood])
}

model MsUserPreference {
  id                           String                 @id @default(cuid())
  userId                       String                 @unique
  primaryGoal                  String
  triggers                     String[]               @default([])
  supportTone                  String
  highRiskAction               String
  accessibilityMode            String[]               @default([])
  textScale                    AccessibilityTextScale @default(STANDARD)
  highContrast                 Boolean                @default(false)
  reducedMotion                Boolean                @default(false)
  screenReaderOptimized        Boolean                @default(false)
  consentToAi                  Boolean                @default(false)
  careChatNotifications        Boolean                @default(false)
  referralNotifications        Boolean                @default(false)
  moodReminderNotifications    Boolean                @default(false)
  wellbeingUpdateNotifications Boolean                @default(false)
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  user                         MsUser                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([primaryGoal])
  @@index([supportTone])
}

model TrReferral {
  id                 String             @id @default(cuid())
  userId             String
  riskLevel          RiskLevel
  reason             String
  requestComment     String?
  backgroundSnapshot Json?
  providerName       String?
  providerType       String?
  contactUrl         String?
  status             ReferralStatus     @default(PENDING)
  reviewerComment    String?
  psychologistId     String?
  reviewedAt         DateTime?
  createdAt          DateTime           @default(now())
  user               MsUser             @relation("ReferralUser", fields: [userId], references: [id], onDelete: Cascade)
  psychologist       MsUser?            @relation("ReferralPsychologist", fields: [psychologistId], references: [id], onDelete: SetNull)
  chatSession        TrCareChatSession?
  voiceTurn          TrVoiceTurn?

  @@index([userId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([riskLevel, createdAt])
  @@index([status, createdAt])
}

model TrPsychologistApplication {
  id             String            @id @default(cuid())
  userId         String            @unique
  fullName       String
  licenseNumber  String
  certificateUrl String
  institution    String?
  reason         String?
  status         ApplicationStatus @default(PENDING)
  reviewComment  String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           MsUser            @relation("PsychologistApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer       MsUser?           @relation("PsychologistApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reviewedById, reviewedAt])
}

model TrCareChatSession {
  id             String              @id @default(cuid())
  referralId     String              @unique
  userId         String
  psychologistId String
  status         ChatSessionStatus   @default(OPEN)
  summary        String?
  closedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  referral       TrReferral          @relation(fields: [referralId], references: [id], onDelete: Cascade)
  user           MsUser              @relation("CareChatUser", fields: [userId], references: [id], onDelete: Cascade)
  psychologist   MsUser              @relation("CareChatPsychologist", fields: [psychologistId], references: [id], onDelete: Cascade)
  messages       TrCareChatMessage[]

  @@index([userId, updatedAt])
  @@index([psychologistId, updatedAt])
}

model TrCareChatMessage {
  id        String            @id @default(cuid())
  sessionId String
  senderId  String
  content   String
  imageUrl  String?
  readAt    DateTime?
  createdAt DateTime          @default(now())
  session   TrCareChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    MsUser            @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([senderId, createdAt])
}

model MsDailyMotivation {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  locale    String
  message   String
  author    String?
  createdAt DateTime @default(now())

  @@unique([date, locale])
  @@index([locale, date])
}

model MsMindfulnessActivity {
  id              String                  @id @default(cuid())
  slug            String                  @unique
  type            MindfulnessType
  title           String
  description     String
  durationSeconds Int
  locale          String
  steps           String[]
  isPublished     Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  progress        TrMindfulnessProgress[]

  @@index([locale, isPublished, type])
}

model TrMindfulnessProgress {
  id              String                    @id @default(cuid())
  userId          String
  activityId      String
  status          MindfulnessProgressStatus @default(STARTED)
  progressSeconds Int                       @default(0)
  startedAt       DateTime                  @default(now())
  completedAt     DateTime?
  updatedAt       DateTime                  @updatedAt
  user            MsUser                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity        MsMindfulnessActivity     @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([userId, updatedAt])
}

model MsEmergencyContact {
  id           String   @id @default(cuid())
  userId       String
  name         String
  relationship String
  phone        String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         MsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary, createdAt])
}

model MsProvider {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  type        ProviderType
  description String
  phone       String?
  websiteUrl  String?
  address     String?
  region      String
  languages   String[]
  isEmergency Boolean      @default(false)
  isVerified  Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([region, isActive, type])
  @@index([isEmergency, isActive])
}
