generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MoodState {
  HAPPY
  CALM
  NEUTRAL
  ANXIOUS
  SAD
  DISTRESSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRISIS
}

enum UserRole {
  USER
  PSYCHOLOGIST
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ChatSessionStatus {
  OPEN
  CLOSED
}

model User {
  id                         String                   @id @default(cuid())
  firebaseUid                String                   @unique
  email                      String?                  @unique
  displayName                String?
  role                       UserRole                 @default(USER)
  avatarUrl                  String?
  bio                        String?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  moods                      Mood[]
  journals                   JournalEntry[]
  posts                      CommunityPost[]
  communitySupports         CommunitySupport[]
  moodGeoPoints              MoodGeoPoint[]
  referrals                  Referral[]
  reviewedReferrals          Referral[]               @relation("ReferralPsychologist")
  careChatSessions           CareChatSession[]        @relation("CareChatUser")
  psychologistChatSessions   CareChatSession[]        @relation("CareChatPsychologist")
  careChatMessages           CareChatMessage[]
  preference                 UserPreference?
  psychologistApplication    PsychologistApplication?

  @@index([role])
  @@index([createdAt])
}

model Mood {
  id        String     @id @default(cuid())
  userId    String
  state     MoodState
  intensity Int        @default(3)
  triggers  String[]   @default([])
  note      String?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([state, createdAt])
}

model JournalEntry {
  id              String     @id @default(cuid())
  userId          String
  title           String
  content        String
  imageUrl       String?
  detectedMood   MoodState?
  riskLevel       RiskLevel  @default(LOW)
  aiReflection    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([riskLevel, createdAt])
}

model CommunityPost {
  id          String    @id @default(cuid())
  userId      String?
  alias       String    @default("Anonymous")
  content     String
  imageUrl    String?
  mood        MoodState?
  supportCount Int      @default(0)
  isHidden    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  supports    CommunitySupport[]
  comments    CommunityComment[]

  @@index([createdAt])
  @@index([isHidden, createdAt])
}

model CommunitySupport {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String?
  alias     String   @default("Anonymous")
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model MoodGeoPoint {
  id          String    @id @default(cuid())
  userId      String?
  regionLabel String
  latitude    Float
  longitude   Float
  mood        MoodState
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([regionLabel, createdAt])
  @@index([mood, createdAt])
}

model UserPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  primaryGoal       String
  triggers          String[] @default([])
  supportTone       String
  highRiskAction    String
  accessibilityMode String[] @default([])
  consentToAi       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([primaryGoal])
  @@index([supportTone])
}

model Referral {
  id                  String           @id @default(cuid())
  userId              String
  riskLevel           RiskLevel
  reason              String
  requestComment      String?
  backgroundSnapshot  Json?
  providerName        String?
  providerType        String?
  contactUrl          String?
  status              ReferralStatus   @default(PENDING)
  reviewerComment     String?
  psychologistId      String?
  reviewedAt          DateTime?
  createdAt           DateTime         @default(now())
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  psychologist        User?            @relation("ReferralPsychologist", fields: [psychologistId], references: [id], onDelete: SetNull)
  chatSession         CareChatSession?

  @@index([userId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([riskLevel, createdAt])
  @@index([status, createdAt])
}

model PsychologistApplication {
  id             String            @id @default(cuid())
  userId         String            @unique
  fullName       String
  licenseNumber  String
  certificateUrl String
  institution    String?
  reason         String?
  status         ApplicationStatus @default(PENDING)
  reviewComment  String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model CareChatSession {
  id              String            @id @default(cuid())
  referralId      String            @unique
  userId          String
  psychologistId  String
  status          ChatSessionStatus @default(OPEN)
  summary         String?
  closedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  referral        Referral          @relation(fields: [referralId], references: [id], onDelete: Cascade)
  user            User              @relation("CareChatUser", fields: [userId], references: [id], onDelete: Cascade)
  psychologist    User              @relation("CareChatPsychologist", fields: [psychologistId], references: [id], onDelete: Cascade)
  messages        CareChatMessage[]

  @@index([userId, updatedAt])
  @@index([psychologistId, updatedAt])
}

model CareChatMessage {
  id          String          @id @default(cuid())
  sessionId   String
  senderId    String
  content     String
  imageUrl    String?
  readAt      DateTime?
  createdAt   DateTime        @default(now())
  session     CareChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender      User            @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([senderId, createdAt])
}
